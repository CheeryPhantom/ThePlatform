# Supabase Postgres connection string (Transaction pooler URL recommended for serverless)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# API security
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.vercel.app

# Database TLS and pooling behavior
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=10000

# Supabase Storage (for resume, profile-photo, logo, certificate uploads)
# Service role key is server-only. Never expose to the frontend.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
# Bucket names (create these once in Supabase Studio > Storage)
SUPABASE_RESUME_BUCKET=resumes
SUPABASE_PHOTO_BUCKET=profile-photos
SUPABASE_LOGO_BUCKET=employer-logos
SUPABASE_CERT_BUCKET=certificates
SUPABASE_COVER_BUCKET=cover-letters
SUPABASE_OTHER_BUCKET=other-uploads
